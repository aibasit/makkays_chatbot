# --- Database ---
SUPABASE_DB_URL=postgresql+asyncpg://postgres:<password>@<host>:6543/postgres
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Vector DB ---
QDRANT_URL=https://<cluster-id>.qdrant.io
QDRANT_API_KEY=

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
# "groq" for the hosted Groq Cloud API (MVP default) or "ollama" once you install a local model
LLM_PROVIDER=groq

# --- LLM: Groq Cloud ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30

# --- LLM: Ollama (used only when LLM_PROVIDER=ollama) ---
# When running inside Docker, use http://host.docker.internal:11434 to reach Ollama on your host
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3

# --- Email ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=sales@yourdomain.com

# --- CRM ---
CRM_PROVIDER=local
CRM_API_BASE_URL=
CRM_API_KEY=

# --- Public API / Widget ---
SITE_API_KEY=

# --- Feature Flags (v4.1) ---
ENABLE_RAG=true
ENABLE_QUOTES=true
ENABLE_CRM=true
ENABLE_TICKETS=true
ENABLE_IMAGE_UPLOAD=false
ENABLE_LLM_CLARIFICATION_REWRITE=false

# --- Feature Flags (v4.2 — Product Intelligence) ---
ENABLE_PRODUCT_COMPARISON=true
ENABLE_COMPATIBILITY_CHECK=true
ENABLE_ACCESSORY_RECOMMENDATION=true
ENABLE_PDF_SEARCH=true

# --- Feature Flags (v4.2 — Solution & Wizard) ---
ENABLE_SOLUTION_BUILDER=true
ENABLE_WIZARD=true
ENABLE_USE_CASE_RECOMMENDATION=true

# --- Feature Flags (v4.2 — Transactional & Ops) ---
ENABLE_HUMAN_HANDOFF=true
ENABLE_AVAILABILITY_CHECK=false
ENABLE_MULTI_LANGUAGE=false

# --- Feature Flags (v4.2 — Future Extension Stubs, always forced False at runtime) ---
ENABLE_VOICE_CHAT=false
ENABLE_IMAGE_UNDERSTANDING=false

# --- LLM Tuning ---
OLLAMA_TIMEOUT_SECONDS=30
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.70

# --- Path Overrides ---
PROMPT_LIBRARY_PATH=./prompt_library
SECURITY_POLICY_DIR=./security_policies

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO

# --- Runtime Defaults ---
CONVERSATION_STATE_TTL_SECONDS=1800
MAX_CLARIFICATION_ROUNDS=2
RAG_SEARCH_LIMIT_DEFAULT=5
RAG_SEARCH_LIMIT_MAX=10
CRM_MAX_RETRY_ATTEMPTS=5
CRM_RETRY_WORKER_INTERVAL_SECONDS=60
CHAT_RATE_LIMIT_PER_MINUTE=20
MAX_MESSAGE_LENGTH=4000

